# FEMU clang-tidy configuration
# Run with: cmake --build build --target clang-tidy
#
# readability-function-size and readability-function-cognitive-complexity are
# enabled at default thresholds as guardrails for new code. A handful of
# established functions that are genuinely *flat opcode/register dispatch
# switches* (e.g. exec_mrs/exec_msr/exec_hint, decode_multiply) carry a
# localized NOLINTNEXTLINE because their score is a false positive. Functions
# that are flagged for genuine nested complexity are intentionally left
# reported.
#
# Enforcement: the bug-finding and quality families (bugprone-*, cert-*,
# modernize-*, performance-*, portability-*) are promoted to errors via
# WarningsAsErrors so they gate CI. clang-analyzer-* is deliberately left
# advisory: clang-analyzer-security.ArrayBound fires false positives on the
# bounded computed-goto interpreter, and clang-analyzer-deadcode.DeadStores
# covers the threaded-interpreter dispatch. The readability-* complexity checks
# are also advisory (intentional flat opcode dispatch).

Checks: >
  -*,
  bugprone-*,
  cert-*,
  clang-analyzer-*,
  misc-*,
  modernize-*,
  performance-*,
  portability-*,
  readability-*,
  -modernize-use-trailing-return-type,
  -modernize-macro-to-enum,
  -readability-magic-numbers,
  -readability-identifier-length,
  -readability-braces-around-statements,
  -readability-isolate-declaration,
  -readability-uppercase-literal-suffix,
  -readability-else-after-return,
  -readability-math-missing-parentheses,
  -bugprone-branch-clone,
  -misc-no-recursion,
  -misc-include-cleaner,
  -bugprone-easily-swappable-parameters,
  -clang-diagnostic-error,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling

WarningsAsErrors: 'bugprone-*,cert-*,modernize-*,performance-*,portability-*'

HeaderFilterRegex: 'include/.*\.h$'

CheckOptions:
  - key: misc-non-private-member-variables-in-classes.IgnoreClassesWithAllMemberVariablesBeingPublic
    value: true
